{
  "tasks": {
    "build": "deno run -A npm:next@14.0.4 build",
    "serve": "deno run --allow-read --allow-net --allow-env serve.ts"
  },
  "deploy": {
    "org": "ubiquity-dao",
    "install": "deno install",
    "build": "deno task build",
    "runtime": {
      "type": "static",
      "cwd": "./out"
    }
  }
}
